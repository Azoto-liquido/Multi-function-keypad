{
    "keyboard_name": "Multi Function Keypad",
    "manufacturer": "Azoto-liquido",
    "maintainer": "Azoto-liquido",
    "usb": {
        "vid": "0x6C61",
        "pid": "0x4D46",
        "device_version": "0.0.1"
    },
    "features": {
        "encoder": true,
        "oled": true,
        "rgb_matrix": true
    },
    "processor": "RP2040",
    "bootloader": "rp2040",
    "matrix_pins": {
        "direct": [["GP1", "GP2", "GP4", "GP3"]]
    },
    "encoder": {
        "rotary": [
            {
                "pin_a":      "GP29",
                "pin_b":      "GP28",
                "resolution": 4
            }
        ]
    },
    "rgb_matrix": {
        "driver": "ws2812",
        "led_count": 2,
        "animations": {
            "solid_color":         true,
            "breathing":           true,
            "cycle_all":           true,
            "cycle_left_right":    true,
            "rainbow_beacon":      true,
            "jellybean_raindrops": true,
            "pixel_rain":          true
        }
    },
    "ws2812": {
        "pin":    "GP0",
        "driver": "vendor"
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                { "matrix": [0, 0], "x": 0, "y": 0, "label": "SW1" },
                { "matrix": [0, 1], "x": 1, "y": 0, "label": "SW2" },
                { "matrix": [0, 2], "x": 2, "y": 0, "label": "SW3" },
                { "matrix": [0, 3], "x": 1, "y": 1, "label": "SW4" }
            ]
        }
    }
}
